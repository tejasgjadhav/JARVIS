# J.A.R.V.I.S. configuration — copy to .env and fill in real values.
# The real .env is git-ignored so your key never gets committed.

# ── Required ──
ANTHROPIC_API_KEY=xx

# ── Server ──
PORT=3000
SESSION_SECRET=jarvis-iron-man-mk42

# ── Claude model routing ──
REPORT_MODEL=claude-opus-4-8          # institutional report — accuracy first
EXTRACT_MODEL=claude-sonnet-5         # ticker extraction
# CHAT_MODEL=claude-haiku-4-5-20251001  # quick chat (optional override)

# ── Voice (local Whisper STT) ──
WHISPER_MODEL=small.en
WHISPER_TASK=transcribe

# ── Validation ──
# VALIDATE_FORMULAS=1                  # also execute Excel formulas in validation (slower)

# ── Optional: Gmail integration ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
